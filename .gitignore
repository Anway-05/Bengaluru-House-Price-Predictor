```gitignore
# -----------------------------
# Python
# -----------------------------
__pycache__/
*.py[cod]
*$py.class

# -----------------------------
# Jupyter Notebook
# -----------------------------
.ipynb_checkpoints/

# -----------------------------
# Virtual Environments
# -----------------------------
venv/
.venv/
env/
ENV/

# -----------------------------
# Environment Variables
# -----------------------------
.env

# -----------------------------
# IDE Settings
# -----------------------------
.vscode/
.idea/

# -----------------------------
# Operating System Files
# -----------------------------
.DS_Store
Thumbs.db

# -----------------------------
# Logs
# -----------------------------
*.log

# -----------------------------
# Build / Distribution
# -----------------------------
build/
dist/
*.egg-info/

# -----------------------------
# Python Cache
# -----------------------------
.pytest_cache/
.mypy_cache/
```
